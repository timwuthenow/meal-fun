        <dmn:inputEntry id="_rule12_input2">
          <dmn:text>"high", "medium"</dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="_rule12_input3">
          <dmn:text>not("packed")</dmn:text>
