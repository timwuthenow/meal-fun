  <!-- DMNDI (Diagram Information) -->
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="_mealSelectorDiagram" name="Meal Selector DRG">
      <!-- Input Data Shapes -->
      <dmndi:DMNShape id="_dayOfWeekShape" dmnElementRef="_dayOfWeek">
        <dc:Bounds x="150" y="300" width="100" height="50"/>
      </dmndi:DMNShape>
      <dmndi:DMNShape id="_energyLevelShape" dmnElementRef="_energyLevel">
        <dc:Bounds x="300" y="300" width="100" height="50"/>
      </dmndi:DMNShape>
      <dmndi:DMNShape id="_scheduleBusynessShape" dmnElementRef="_scheduleBusyness">
        <dc:Bounds x="450" y="300" width="100" height="50"/>
      </dmndi:DMNShape>
      <dmndi:DMNShape id="_weekNumberShape" dmnElementRef="_weekNumber">
        <dc:Bounds x="600" y="300" width="100" height="50"/>
      </dmndi:DMNShape>

      <!-- Decision Shape -->
      <dmndi:DMNShape id="_selectMealShape" dmnElementRef="_selectMeal">
        <dc:Bounds x="350" y="150" width="150" height="80"/>
      </dmndi:DMNShape>

      <!-- Information Requirement Edges -->
      <dmndi:DMNEdge id="_reqDayEdge" dmnElementRef="_reqDay">
        <di:waypoint x="200" y="300"/>
        <di:waypoint x="400" y="230"/>
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="_reqEnergyEdge" dmnElementRef="_reqEnergy">
        <di:waypoint x="350" y="300"/>
        <di:waypoint x="415" y="230"/>
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="_reqScheduleEdge" dmnElementRef="_reqSchedule">
        <di:waypoint x="500" y="300"/>
        <di:waypoint x="450" y="230"/>
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="_reqWeekEdge" dmnElementRef="_reqWeek">
        <di:waypoint x="650" y="300"/>
        <di:waypoint x="480" y="230"/>
      </dmndi:DMNEdge>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</dmn:definitions>
